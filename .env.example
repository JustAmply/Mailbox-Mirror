# Source mailbox
HOST1=imap.source.tld
PORT1=993
USER1=source-user@example.com
PASSWORD1=replace-me
SSL1=true

# Destination mailbox
HOST2=imap.destination.tld
PORT2=993
USER2=target-user@example.com
PASSWORD2=replace-me
SSL2=true

# Cron schedule (every 5 minutes)
CRON_SCHEDULE=*/5 * * * *

# Run one sync directly on container start
RUN_ON_STARTUP=true

# Optional tuning
DRY_RUN=false
# Optional: override the lock file path. Put this on a shared volume when you
# run multiple containers and want only one imapsync process active at a time.
# LOCK_FILE=/var/lock/mailbox-mirror/global.lock
# Rotate imapsync.log once it reaches this size in MB
# MAX_LOG_SIZE_MB=10
# Optional: mark container unhealthy if the last successful sync is older than this
# HEALTHCHECK_MAX_AGE_MINUTES=30
# MAXAGE_DAYS=30
# FOLDER_FILTER=INBOX
# IMAPSYNC_EXTRA_ARGS=--delete2 --expunge2
