# Default setup
HOST1=imap.source.tld
PORT1=993
USER1=source-user@example.com
PASSWORD1=replace-me
SSL1=true

HOST2=imap.destination.tld
PORT2=993
USER2=target-user@example.com
PASSWORD2=replace-me
SSL2=true

CRON_SCHEDULE=*/5 * * * *
RUN_ON_STARTUP=true
DRY_RUN=false

# Optional tuning
# LOCK_FILE=/var/lock/mailbox-mirror/global.lock
# FOLDER_FILTER=INBOX
# MAXAGE_DAYS=30
# HEALTHCHECK_MAX_AGE_MINUTES=30
# IMAPSYNC_EXTRA_ARGS=--delete2 --expunge2
# MAX_LOG_SIZE_MB=10

# Advanced example for docker-compose.multi-mailbox.yml
# Uncomment the mailboxes you need. Reuse the same HOST2/USER2/PASSWORD2 values
# if all sources mirror into the same destination account.

# MAILBOX_A_HOST1=imap.mail.yahoo.com
# MAILBOX_A_PORT1=993
# MAILBOX_A_USER1=mailbox-a@yahoo.com
# MAILBOX_A_PASSWORD1=replace-me
# MAILBOX_A_SSL1=true
# MAILBOX_A_HOST2=imap.gmail.com
# MAILBOX_A_PORT2=993
# MAILBOX_A_USER2=yourname@gmail.com
# MAILBOX_A_PASSWORD2=replace-me
